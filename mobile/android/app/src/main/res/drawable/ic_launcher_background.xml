<?xml version="1.0" encoding="utf-8"?>
<!-- Full-bleed DT-1 brand gradient (2026 logo review) behind the Farry star
     mark. CSS reference: linear-gradient(135deg, #050816, #0A1026, #131B36) —
     android angle 315 = the same top-left → bottom-right direction. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="#050816"
        android:centerColor="#0A1026"
        android:endColor="#131B36" />
</shape>
