# ---------- Python / Backend ----------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.env
.env.*
!.env.example
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.sqlite3
*.db
dist/
build/

# Runtime logs. NEVER commit these: the server logs the `?token=` on the
# /ws/live handshake and (until a real mail provider is wired) the email
# verification / password-reset links, so a run against a real account
# leaves live credentials in the file.
*.log

# ---------- Flutter / Dart / Mobile ----------
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/build/
mobile/.pub-cache/
mobile/.pub/
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/key.properties
*.iml
*.lock
!pubspec.lock

# Built APKs (large binaries; rebuild from mobile/). Keep the folder's README.
apk/*.apk

# Golden PNGs from the design-preview tests. Not a regression gate (they're
# skipped by default and their bytes differ per host), so committing them is
# just binary churn. Regenerate to look at a screen:
#   cd mobile && flutter test --run-skipped --update-goldens test/auth_preview_test.dart
mobile/test/goldens/

# ---------- Web admin panel (React + Vite) ----------
admin/node_modules/
# `*.lock` above would exclude the npm lockfile; keep it for reproducible builds.
!admin/package-lock.json

# Local design mockups (dev artifacts).
mockups/

