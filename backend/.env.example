# FarryOn backend configuration.
# Copy to `.env` and adjust. Every variable has a safe default; the service
# boots with an empty file using the deterministic `mock` AI provider.

# ─── AI provider selection ────────────────────────────────────────────────
# Which realtime model adapter to use: gemini | openai | mock
# `mock` requires no API key or network (used by tests/demos).
AI_PROVIDER=mock

# Gemini Live (AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest

# OpenAI Realtime (AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime

# Grok / xAI Realtime (AI_PROVIDER=grok) — OpenAI Realtime-compatible endpoint.
GROK_API_KEY=
GROK_REALTIME_MODEL=grok-realtime

# AI_PROVIDER above is the server DEFAULT. The app can also pick a provider
# per-session (hello.provider); only these are allowed:
ALLOWED_PROVIDERS=gemini,openai,grok,mock

# ─── Database ─────────────────────────────────────────────────────────────
# Async SQLAlchemy URL.
#   dev / CI : sqlite+aiosqlite:///./farryon.db   (or :memory: for tests)
#   prod     : postgresql+asyncpg://user:pass@host:5432/farryon
DATABASE_URL=sqlite+aiosqlite:///./farryon.db

# ─── Vision: landmark & product finder ────────────────────────────────────
# Google Cloud Vision API key (LANDMARK_DETECTION + WEB_DETECTION). Powers the
# `identify_image` tool and the `POST /detect` endpoint. Get one from the Google
# Cloud Console (enable "Cloud Vision API" → Credentials → API key).
# 1,000 images/month free, then ~$1.50/1,000. The product AI explanation reuses
# GEMINI_API_KEY above — no separate key needed.
VISION_API_KEY=

# ─── live vision frame gate (cost control) ────────────────────────────────
# Camera frames are the #1 Gemini Live cost driver (every frame is re-billed on
# every later turn). This gate decides how many reach the model. Vision still
# works in all modes: identify_image reads the latest cached frame, typed turns
# attach a fresh one, and a frame capture_photo is waiting for is never dropped.
#   continuous -> forward frames, throttled to VISION_FRAME_MIN_INTERVAL_S
#   on_turn    -> forward at most one frame per VISION_FRAME_HEARTBEAT_S (default)
#   off        -> never stream; cache for identify_image only
VISION_FRAME_MODE=on_turn
VISION_FRAME_MIN_INTERVAL_S=2.0
VISION_FRAME_HEARTBEAT_S=6.0

# ─── live session cost control ────────────────────────────────────────────
# Sliding-window context compression: past TRIGGER tokens, only the most recent
# TARGET tokens are kept/re-billed each turn (Live re-bills the whole history).
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_TRIGGER_TOKENS=16000
CONTEXT_TARGET_TOKENS=8000
# Bound runaway/idle sessions (server sends session_expired + closes; the app
# reconnects fresh). 0 disables a cap. Seconds.
MAX_SESSION_SECONDS=1800
IDLE_DISCONNECT_SECONDS=300
# Cap tool results fed back to the model (the app UI still gets the full one).
TOOL_RESULT_MAX_CHARS=2000

# ─── per-user daily quotas ────────────────────────────────────────────────
# OFF by default (quotas need real per-user auth). Turn on for launch. The
# per-plan caps live in config.py (plan_limits); 0 = off, -1 = unlimited.
QUOTA_ENFORCEMENT_ENABLED=false
DEFAULT_PLAN=free

# ─── web_search tool ──────────────────────────────────────────────────────
# Primary backend: mock | tavily | serper | serpapi. With `mock` (or no key)
# it returns deterministic offline results — no network call is made.
#   tavily -> free 1,000 searches/mo, no card   (https://tavily.com)
#   serper -> free 2,500 searches, no card       (https://serper.dev)
WEB_SEARCH_PROVIDER=mock
WEB_SEARCH_API_KEY=
# Optional fallback: used automatically when the primary errors or runs out of
# free credits (HTTP 401/402/429). Chain two free tiers to maximise free usage,
# e.g. PROVIDER=tavily + FALLBACK_PROVIDER=serper.
WEB_SEARCH_FALLBACK_PROVIDER=
WEB_SEARCH_FALLBACK_API_KEY=

# ─── Observability ────────────────────────────────────────────────────────
# Root log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── Security / HTTP ──────────────────────────────────────────────────────
# HMAC secret for verifying the ?token= JWT on /ws/live.
# Auth is ENFORCED only when this differs from the default below; leaving the
# default disables auth for local development.
JWT_SECRET=dev-insecure-change-me

# CORS allow-list (comma-separated). "*" allows all origins.
ALLOWED_ORIGINS=*

# ─── Admin/User module ────────────────────────────────────────────────────
# Access/refresh token lifetimes issued by /auth/* (admin/user module).
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# One-time bootstrap: set both to create (or promote) this account to
# super_admin the next time `python -m scripts.seed_admin` runs (also safe to
# leave set — re-running only re-grants the role, never overwrites the
# password). Unset after the first successful production seed.
FIRST_SUPER_ADMIN_EMAIL=
FIRST_SUPER_ADMIN_PASSWORD=

# SSO (Google / Microsoft) — leave unset to disable; /auth/sso/{provider}/*
# returns 503 SSO_NOT_CONFIGURED until both id+secret are set for a provider.
# GOOGLE_CLIENT_ID must be the *Web* client id: the phone's native sign-in
# (google_sign_in) is handed the same value as `serverClientId`, so Google mints
# its ID token with this as the audience and the backend can verify it.
# GOOGLE_CLIENT_SECRET is only needed for the admin panel's redirect flow.
# Full walkthrough: docs/GOOGLE_SIGN_IN_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
# Must match a redirect URI registered with the provider, e.g.
# https://api.farryon.app (no trailing slash) in production.
SSO_REDIRECT_BASE_URL=http://localhost:8000
# If set, the OAuth callback redirects here with ?access_token=&refresh_token=
# instead of returning JSON — point this at the admin/mobile app's own route.
SSO_FRONTEND_SUCCESS_URL=
# Secret for the OAuth CSRF-state cookie (authlib/Starlette SessionMiddleware).
# Defaults to JWT_SECRET if unset.
SESSION_SECRET=

# Billing webhook shared secret (X-Webhook-Secret header). Webhooks return
# 503 until this is set. Placeholder until a real provider's HMAC signature
# verification (Stripe/Razorpay) replaces it.
BILLING_WEBHOOK_SECRET=

# Bind address for uvicorn.
HOST=0.0.0.0
PORT=8000

# ─── Tunables ─────────────────────────────────────────────────────────────
# Per-tool execution timeout in seconds.
TOOL_TIMEOUT_SECONDS=20

# Max seconds a vision tool (identify_image / capture_photo) waits for a fresh
# camera frame. Phone cameras stream ~1 fps, so the phone value only caps the
# failure path. Smart glasses are photo-trigger: capture + BLE thumbnail
# transfer runs 3-5 s in isolation but balloons to 10-12 s in a live voice
# session (the glasses' A2DP audio link contends for the radio), so the glasses
# value must outlast that. The success path is event-driven (the frame wakes
# the wait early), so a longer budget only affects the failure backstop.
FRAME_WAIT_SECONDS=8.0
GLASSES_FRAME_WAIT_SECONDS=18.0
# After a one-shot glasses photo arrives, capture_photo pauses this long before
# returning (which triggers the model's "describe what you see" reply), so the
# model's realtime-video pipeline ingests the frame first. Without it the model
# replies before it has "seen" the photo and hallucinates the scene.
FRAME_INGEST_SECONDS=1.2
